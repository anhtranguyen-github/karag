{
  "openapi": "3.1.0",
  "info": {
    "title": "Karag Workspace & Document API",
    "description": "Internal infrastructure APIs for workspace and document management in the Karag RAG system.",
    "version": "1.0.0",
    "contact": {
      "name": "Karag API Team"
    }
  },
  "servers": [
    {
      "url": "/api/v1",
      "description": "Base API path"
    }
  ],
  "tags": [
    {
      "name": "Workspaces",
      "description": "Workspace management operations"
    },
    {
      "name": "Documents",
      "description": "Document upload, processing, and management"
    },
    {
      "name": "Tasks",
      "description": "Background task monitoring"
    }
  ],
  "paths": {
    "/workspaces": {
      "get": {
        "summary": "List Workspaces",
        "description": "List all workspaces for the authenticated user",
        "tags": ["Workspaces"],
        "operationId": "listWorkspaces",
        "parameters": [
          {
            "name": "page",
            "in": "query",
            "schema": {"type": "integer", "default": 1}
          },
          {
            "name": "per_page",
            "in": "query",
            "schema": {"type": "integer", "default": 20, "maximum": 100}
          },
          {
            "name": "status",
            "in": "query",
            "schema": {"type": "string", "enum": ["active", "archived", "maintenance"]}
          }
        ],
        "responses": {
          "200": {
            "description": "List of workspaces",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AppResponse"
                },
                "example": {
                  "success": true,
                  "code": "SUCCESS",
                  "message": "Workspaces retrieved",
                  "data": {
                    "workspaces": [
                      {
                        "id": "ws_abc123",
                        "name": "Research Project",
                        "slug": "research-project",
                        "description": "AI safety research documents",
                        "status": "active",
                        "stats": {
                          "document_count": 42,
                          "thread_count": 15,
                          "storage_bytes": 104857600
                        },
                        "capabilities": {
                          "rag_engine": "graph",
                          "embedding_provider": "openai",
                          "llm_provider": "openai"
                        }
                      }
                    ]
                  }
                }
              }
            }
          }
        }
      },
      "post": {
        "summary": "Create Workspace",
        "description": "Create a new workspace with specified configuration",
        "tags": ["Workspaces"],
        "operationId": "createWorkspace",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/WorkspaceCreate"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Workspace created successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AppResponse"
                }
              }
            }
          },
          "409": {
            "description": "Workspace name already exists"
          }
        }
      }
    },
    "/workspaces/{workspace_id}": {
      "get": {
        "summary": "Get Workspace",
        "description": "Get detailed workspace information",
        "tags": ["Workspaces"],
        "operationId": "getWorkspace",
        "parameters": [
          {
            "$ref": "#/components/parameters/WorkspaceIdParam"
          }
        ],
        "responses": {
          "200": {
            "description": "Workspace details",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AppResponse"
                }
              }
            }
          },
          "404": {
            "description": "Workspace not found"
          }
        }
      },
      "patch": {
        "summary": "Update Workspace",
        "description": "Update workspace metadata (RAG settings immutable)",
        "tags": ["Workspaces"],
        "operationId": "updateWorkspace",
        "parameters": [
          {
            "$ref": "#/components/parameters/WorkspaceIdParam"
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/WorkspaceUpdate"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Workspace updated"
          },
          "409": {
            "description": "Name already exists"
          }
        }
      },
      "delete": {
        "summary": "Delete Workspace",
        "description": "Delete workspace and all associated data",
        "tags": ["Workspaces"],
        "operationId": "deleteWorkspace",
        "parameters": [
          {
            "$ref": "#/components/parameters/WorkspaceIdParam"
          },
          {
            "name": "vault_delete",
            "in": "query",
            "schema": {"type": "boolean", "default": false}
          }
        ],
        "responses": {
          "202": {
            "description": "Deletion initiated"
          }
        }
      }
    },
    "/workspaces/{workspace_id}/clone": {
      "post": {
        "summary": "Clone Workspace",
        "description": "Clone workspace with new configuration (allows changing RAG settings)",
        "tags": ["Workspaces"],
        "operationId": "cloneWorkspace",
        "parameters": [
          {
            "$ref": "#/components/parameters/WorkspaceIdParam"
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "name": {"type": "string"},
                  "description": {"type": "string"},
                  "rag_profile": {"type": "string", "enum": ["default", "fast", "accurate", "research"]},
                  "copy_documents": {"type": "boolean", "default": true},
                  "copy_threads": {"type": "boolean", "default": false}
                },
                "required": ["name"]
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Workspace cloned"
          }
        }
      }
    },
    "/workspaces/{workspace_id}/settings": {
      "get": {
        "summary": "Get Workspace Settings",
        "description": "Get full workspace settings with mutability indicators",
        "tags": ["Workspaces"],
        "operationId": "getWorkspaceSettings",
        "parameters": [
          {
            "$ref": "#/components/parameters/WorkspaceIdParam"
          }
        ],
        "responses": {
          "200": {
            "description": "Workspace settings",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AppResponse"
                }
              }
            }
          }
        }
      }
    },
    "/workspaces/{workspace_id}/settings/validate": {
      "post": {
        "summary": "Validate Settings Change",
        "description": "Validate proposed settings changes before applying",
        "tags": ["Workspaces"],
        "operationId": "validateSettingsChange",
        "parameters": [
          {
            "$ref": "#/components/parameters/WorkspaceIdParam"
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "proposed_settings": {"type": "object"}
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Validation result"
          }
        }
      }
    },
    "/workspaces/{workspace_id}/stats": {
      "get": {
        "summary": "Get Workspace Statistics",
        "description": "Get comprehensive workspace statistics",
        "tags": ["Workspaces"],
        "operationId": "getWorkspaceStats",
        "parameters": [
          {
            "$ref": "#/components/parameters/WorkspaceIdParam"
          }
        ],
        "responses": {
          "200": {
            "description": "Workspace statistics",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AppResponse"
                }
              }
            }
          }
        }
      }
    },
    "/workspaces/{workspace_id}/graph": {
      "get": {
        "summary": "Get Workspace Graph",
        "description": "Get knowledge graph data for visualization",
        "tags": ["Workspaces"],
        "operationId": "getWorkspaceGraph",
        "parameters": [
          {
            "$ref": "#/components/parameters/WorkspaceIdParam"
          }
        ],
        "responses": {
          "200": {
            "description": "Graph data with nodes and edges"
          }
        }
      }
    },
    "/workspaces/{workspace_id}/reindex": {
      "post": {
        "summary": "Trigger Re-indexing",
        "description": "Trigger full or partial workspace re-indexing",
        "tags": ["Workspaces"],
        "operationId": "reindexWorkspace",
        "parameters": [
          {
            "$ref": "#/components/parameters/WorkspaceIdParam"
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "scope": {"type": "string", "enum": ["failed_only", "all", "document_ids"]},
                  "document_ids": {"type": "array", "items": {"type": "string"}},
                  "force": {"type": "boolean", "default": false}
                }
              }
            }
          }
        },
        "responses": {
          "202": {
            "description": "Re-indexing initiated"
          }
        }
      }
    },
    "/workspaces/{workspace_id}/share-document": {
      "post": {
        "summary": "Share Document",
        "description": "Share document across workspaces",
        "tags": ["Workspaces"],
        "operationId": "shareDocument",
        "parameters": [
          {
            "$ref": "#/components/parameters/WorkspaceIdParam"
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "document_id": {"type": "string"},
                  "target_workspace_id": {"type": "string"}
                },
                "required": ["document_id", "target_workspace_id"]
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Document shared"
          }
        }
      }
    },
    "/workspaces/{workspace_id}/documents": {
      "get": {
        "summary": "List Documents",
        "description": "List documents in workspace with filtering and pagination",
        "tags": ["Documents"],
        "operationId": "listDocuments",
        "parameters": [
          {
            "$ref": "#/components/parameters/WorkspaceIdParam"
          },
          {
            "name": "status",
            "in": "query",
            "schema": {"type": "string"}
          },
          {
            "name": "source_type",
            "in": "query",
            "schema": {"type": "string"}
          },
          {
            "name": "search",
            "in": "query",
            "schema": {"type": "string"},
            "description": "Search in filename and title"
          },
          {
            "name": "page",
            "in": "query",
            "schema": {"type": "integer", "default": 1}
          },
          {
            "name": "per_page",
            "in": "query",
            "schema": {"type": "integer", "default": 20}
          }
        ],
        "responses": {
          "200": {
            "description": "List of documents",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AppResponse"
                }
              }
            }
          }
        }
      }
    },
    "/workspaces/{workspace_id}/documents/upload": {
      "post": {
        "summary": "Upload Document",
        "description": "Upload a file for processing and indexing",
        "tags": ["Documents"],
        "operationId": "uploadDocument",
        "parameters": [
          {
            "$ref": "#/components/parameters/WorkspaceIdParam"
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "multipart/form-data": {
              "schema": {
                "type": "object",
                "properties": {
                  "file": {
                    "type": "string",
                    "format": "binary"
                  },
                  "auto_index": {
                    "type": "boolean",
                    "default": true
                  },
                  "metadata": {
                    "type": "string",
                    "description": "JSON string with metadata"
                  }
                },
                "required": ["file"]
              }
            }
          }
        },
        "responses": {
          "202": {
            "description": "Upload accepted, processing queued",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AppResponse"
                }
              }
            }
          },
          "413": {
            "description": "File too large"
          },
          "415": {
            "description": "Unsupported media type"
          }
        }
      }
    },
    "/workspaces/{workspace_id}/documents/import/url": {
      "post": {
        "summary": "Import from URL",
        "description": "Import document from a URL",
        "tags": ["Documents"],
        "operationId": "importUrl",
        "parameters": [
          {
            "$ref": "#/components/parameters/WorkspaceIdParam"
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/UrlImportRequest"
              }
            }
          }
        },
        "responses": {
          "202": {
            "description": "Import queued"
          }
        }
      }
    },
    "/workspaces/{workspace_id}/documents/import/sitemap": {
      "post": {
        "summary": "Import from Sitemap",
        "description": "Import documents from a sitemap.xml",
        "tags": ["Documents"],
        "operationId": "importSitemap",
        "parameters": [
          {
            "$ref": "#/components/parameters/WorkspaceIdParam"
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/SitemapImportRequest"
              }
            }
          }
        },
        "responses": {
          "202": {
            "description": "Sitemap import queued"
          }
        }
      }
    },
    "/workspaces/{workspace_id}/documents/import/github": {
      "post": {
        "summary": "Import from GitHub",
        "description": "Import documents from a GitHub repository",
        "tags": ["Documents"],
        "operationId": "importGitHub",
        "parameters": [
          {
            "$ref": "#/components/parameters/WorkspaceIdParam"
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/GitHubImportRequest"
              }
            }
          }
        },
        "responses": {
          "202": {
            "description": "GitHub import queued"
          }
        }
      }
    },
    "/workspaces/{workspace_id}/documents/import/audio": {
      "post": {
        "summary": "Import Audio",
        "description": "Upload audio file for transcription and indexing",
        "tags": ["Documents"],
        "operationId": "importAudio",
        "parameters": [
          {
            "$ref": "#/components/parameters/WorkspaceIdParam"
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "multipart/form-data": {
              "schema": {
                "type": "object",
                "properties": {
                  "file": {"type": "string", "format": "binary"},
                  "language": {"type": "string"},
                  "speaker_diarization": {"type": "boolean", "default": false}
                },
                "required": ["file"]
              }
            }
          }
        },
        "responses": {
          "202": {
            "description": "Audio import queued"
          }
        }
      }
    },
    "/workspaces/{workspace_id}/documents/{document_id}": {
      "get": {
        "summary": "Get Document",
        "description": "Get document metadata and status",
        "tags": ["Documents"],
        "operationId": "getDocument",
        "parameters": [
          {
            "$ref": "#/components/parameters/WorkspaceIdParam"
          },
          {
            "$ref": "#/components/parameters/DocumentIdParam"
          }
        ],
        "responses": {
          "200": {
            "description": "Document details"
          },
          "404": {
            "description": "Document not found"
          }
        }
      },
      "delete": {
        "summary": "Delete Document",
        "description": "Delete document with cascading cleanup",
        "tags": ["Documents"],
        "operationId": "deleteDocument",
        "parameters": [
          {
            "$ref": "#/components/parameters/WorkspaceIdParam"
          },
          {
            "$ref": "#/components/parameters/DocumentIdParam"
          },
          {
            "name": "vault",
            "in": "query",
            "schema": {"type": "boolean", "default": false}
          }
        ],
        "responses": {
          "200": {
            "description": "Document deleted"
          }
        }
      }
    },
    "/workspaces/{workspace_id}/documents/{document_id}/content": {
      "get": {
        "summary": "Get Document Content",
        "description": "Get raw document content (internal use only)",
        "tags": ["Documents"],
        "operationId": "getDocumentContent",
        "parameters": [
          {
            "$ref": "#/components/parameters/WorkspaceIdParam"
          },
          {
            "$ref": "#/components/parameters/DocumentIdParam"
          }
        ],
        "responses": {
          "200": {
            "description": "Document content"
          }
        }
      }
    },
    "/workspaces/{workspace_id}/documents/{document_id}/chunks": {
      "get": {
        "summary": "Get Document Chunks",
        "description": "Get text chunks for a document",
        "tags": ["Documents"],
        "operationId": "getDocumentChunks",
        "parameters": [
          {
            "$ref": "#/components/parameters/WorkspaceIdParam"
          },
          {
            "$ref": "#/components/parameters/DocumentIdParam"
          },
          {
            "name": "limit",
            "in": "query",
            "schema": {"type": "integer", "default": 100}
          },
          {
            "name": "offset",
            "in": "query",
            "schema": {"type": "integer", "default": 0}
          }
        ],
        "responses": {
          "200": {
            "description": "Document chunks"
          }
        }
      }
    },
    "/workspaces/{workspace_id}/documents/{document_id}/status": {
      "get": {
        "summary": "Get Document Status",
        "description": "Get detailed processing status with progress",
        "tags": ["Documents"],
        "operationId": "getDocumentStatus",
        "parameters": [
          {
            "$ref": "#/components/parameters/WorkspaceIdParam"
          },
          {
            "$ref": "#/components/parameters/DocumentIdParam"
          }
        ],
        "responses": {
          "200": {
            "description": "Document status with progress"
          }
        }
      }
    },
    "/workspaces/{workspace_id}/documents/{document_id}/index": {
      "post": {
        "summary": "Trigger Indexing",
        "description": "Queue document for indexing",
        "tags": ["Documents"],
        "operationId": "indexDocument",
        "parameters": [
          {
            "$ref": "#/components/parameters/WorkspaceIdParam"
          },
          {
            "$ref": "#/components/parameters/DocumentIdParam"
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "force": {"type": "boolean", "default": false},
                  "priority": {"type": "string", "enum": ["low", "normal", "high"], "default": "normal"}
                }
              }
            }
          }
        },
        "responses": {
          "202": {
            "description": "Indexing queued"
          }
        }
      }
    },
    "/workspaces/{workspace_id}/documents/{document_id}/reindex": {
      "post": {
        "summary": "Force Re-index",
        "description": "Force re-indexing of document (clears existing vectors)",
        "tags": ["Documents"],
        "operationId": "reindexDocument",
        "parameters": [
          {
            "$ref": "#/components/parameters/WorkspaceIdParam"
          },
          {
            "$ref": "#/components/parameters/DocumentIdParam"
          }
        ],
        "responses": {
          "202": {
            "description": "Re-indexing queued"
          }
        }
      }
    },
    "/workspaces/{workspace_id}/documents/{document_id}/cancel": {
      "post": {
        "summary": "Cancel Processing",
        "description": "Cancel ongoing document processing",
        "tags": ["Documents"],
        "operationId": "cancelProcessing",
        "parameters": [
          {
            "$ref": "#/components/parameters/WorkspaceIdParam"
          },
          {
            "$ref": "#/components/parameters/DocumentIdParam"
          }
        ],
        "responses": {
          "200": {
            "description": "Processing cancelled"
          }
        }
      }
    },
    "/workspaces/{workspace_id}/documents/{document_id}/inspect": {
      "get": {
        "summary": "Inspect Document",
        "description": "Get detailed inspection data for debugging",
        "tags": ["Documents"],
        "operationId": "inspectDocument",
        "parameters": [
          {
            "$ref": "#/components/parameters/WorkspaceIdParam"
          },
          {
            "$ref": "#/components/parameters/DocumentIdParam"
          }
        ],
        "responses": {
          "200": {
            "description": "Inspection data"
          }
        }
      }
    },
    "/workspaces/{workspace_id}/documents/batch/delete": {
      "post": {
        "summary": "Batch Delete",
        "description": "Delete multiple documents at once",
        "tags": ["Documents"],
        "operationId": "batchDelete",
        "parameters": [
          {
            "$ref": "#/components/parameters/WorkspaceIdParam"
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "document_ids": {"type": "array", "items": {"type": "string"}},
                  "vault": {"type": "boolean", "default": false}
                },
                "required": ["document_ids"]
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Batch delete completed"
          }
        }
      }
    },
    "/workspaces/{workspace_id}/documents/batch/index": {
      "post": {
        "summary": "Batch Index",
        "description": "Queue multiple documents for indexing",
        "tags": ["Documents"],
        "operationId": "batchIndex",
        "parameters": [
          {
            "$ref": "#/components/parameters/WorkspaceIdParam"
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "document_ids": {"type": "array", "items": {"type": "string"}},
                  "force": {"type": "boolean", "default": false}
                },
                "required": ["document_ids"]
              }
            }
          }
        },
        "responses": {
          "202": {
            "description": "Batch indexing queued"
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "AppResponse": {
        "type": "object",
        "properties": {
          "success": {"type": "boolean"},
          "code": {"type": "string"},
          "message": {"type": "string"},
          "data": {}
        },
        "required": ["success", "code", "message"]
      },
      "Workspace": {
        "type": "object",
        "properties": {
          "id": {"type": "string"},
          "name": {"type": "string"},
          "slug": {"type": "string"},
          "description": {"type": "string", "nullable": true},
          "owner_id": {"type": "string"},
          "created_at": {"type": "string", "format": "date-time"},
          "updated_at": {"type": "string", "format": "date-time"},
          "status": {"type": "string", "enum": ["active", "archived", "maintenance"]},
          "stats": {
            "type": "object",
            "properties": {
              "document_count": {"type": "integer"},
              "thread_count": {"type": "integer"},
              "storage_bytes": {"type": "integer"}
            }
          },
          "capabilities": {
            "type": "object",
            "properties": {
              "rag_engine": {"type": "string"},
              "embedding_provider": {"type": "string"},
              "llm_provider": {"type": "string"}
            }
          }
        },
        "required": ["id", "name", "owner_id", "created_at"]
      },
      "WorkspaceCreate": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string",
            "minLength": 1,
            "maxLength": 50,
            "pattern": "^[\\w\\s.-]+$"
          },
          "description": {"type": "string", "maxLength": 500},
          "rag_profile": {
            "type": "string",
            "enum": ["default", "fast", "accurate", "research"]
          },
          "embedding": {
            "type": "object",
            "properties": {
              "provider": {"type": "string"},
