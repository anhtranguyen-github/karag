APP_NAME=Karag Enterprise RAG Platform
NEXT_PUBLIC_API_URL=http://localhost:8000
PLATFORM_API_PROXY_TARGET=http://localhost:8000
DATABASE_URL=postgresql+psycopg://karag:karag@postgres:5432/karag

DEFAULT_VECTOR_STORE=qdrant
DEFAULT_STORAGE_PROVIDER=minio
DEFAULT_EVENT_BUS=redis-streams
DEFAULT_EMBEDDING_PROVIDER=ollama
DEFAULT_LLM_PROVIDER=ollama
DEFAULT_QDRANT_COLLECTION=knowledge_chunks
DEFAULT_CHUNK_SIZE=48
REDACT_LLM_CONTENT=true
UNREDACTED_WORKSPACE_IDS=

POSTGRES_DB=karag
POSTGRES_USER=karag
POSTGRES_PASSWORD=karag
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

REDIS_URL=redis://redis:6379/0
REDIS_STREAM_NAME=karag.events

QDRANT_URL=http://qdrant:6333
QDRANT_COLLECTION=knowledge_chunks
QDRANT_API_KEY=

MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=karag
MINIO_SECURE=false

KEYCLOAK_URL=http://keycloak:8080
KEYCLOAK_REALM=karag
KEYCLOAK_CLIENT_ID=karag-platform
KEYCLOAK_CLIENT_SECRET=change-me

KONG_ADMIN_URL=http://kong:8001

OLLAMA_BASE_URL=http://ollama:11434
VLLM_BASE_URL=http://vllm:8000
VLLM_MODEL=meta-llama/Llama-3.1-8B-Instruct
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_API_KEY=

OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4318
PROMETHEUS_URL=http://prometheus:9090
TEMPO_URL=http://tempo:3200
LOKI_URL=http://loki:3100
GRAFANA_URL=http://grafana:3001
