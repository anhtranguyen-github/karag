# Auto-detect text files and perform LF normalization
* text=auto

# Handle standard text files
*.py text eol=lf
*.js text eol=lf
*.ts text eol=lf
*.tsx text eol=lf
*.css text eol=lf
*.html text eol=lf
*.json text eol=lf
*.yaml text eol=lf
*.yml text eol=lf
*.md text eol=lf
*.sh text eol=lf

# Explicitly mark binary files
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.pdf binary
*.zip binary
*.tar.gz binary

# Jenkins & Docker
Jenkinsfile text eol=lf
Dockerfile text eol=lf
docker-compose.yml text eol=lf
.dockerignore text eol=lf
.gitignore text eol=lf
