{
    "version": 2,
    "builds": [
        {
            "src": "src/frontend/package.json",
            "use": "@vercel/next"
        }
    ],
    "rewrites": [
        {
            "source": "/(.*)",
            "destination": "/src/frontend/$1"
        }
    ],
    "env": {
        "PYTHON_VERSION": "3.10"
    }
}

